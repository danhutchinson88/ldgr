# Plaid API credentials
# Get these from https://dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox                        # sandbox | production

# Plaid access tokens — generated by: npm run link
# Run link server, connect each institution, copy tokens printed in terminal
PLAID_TOKEN_AMEX=
PLAID_TOKEN_CHASE=
PLAID_TOKEN_FIDELITY=
PLAID_TOKEN_GOLDMAN_SACHS=

# Email digest (weekly Sunday 8am ET)
# Gmail: myaccount.google.com → Security → App Passwords
EMAIL_FROM=you@gmail.com
EMAIL_APP_PASSWORD=
EMAIL_TO=you@gmail.com

# Dashboard
DASHBOARD_PASSWORD=                      # password to access the web UI
SNAPSHOT_PATH=./data/snapshot.json      # local path; Railway uses /data/snapshot.json

# OAuth redirect URI — must match what is registered in the Plaid dashboard
# Required for OAuth-based institutions (Amex, Chase)
PLAID_REDIRECT_URI=https://ldgr.up.railway.app/oauth-return

# Railway deployment (only needed for scripts/push-snapshot.js)
# LDGR_URL=https://your-app.up.railway.app
